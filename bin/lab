create_all_nodes() {
echo "[*] Creating overlays, seed ISOs, and VMs…"
for n in "${!NODES[@]}"; do
  read -r mem vcpus _ _ <<<"${NODES[$n]}"
  echo "  -> $n"
  create_node "$n" "$mem" "$vcpus"
done
}

wait_for_ping() {
local secs=100
echo -n "Waiting ${secs} seconds for IPs to become reachable..."
local nodelist="$(for n in "${!NODES[@]}"; do echo $n; done)"
while test -n "$nodelist"; do
  node=$(echo "$nodelist" | shuf | head -n1)
  ip=$(node_ip $node)
  if ping -c 1 -W 1 "$ip" > /dev/null 2>&1; then
    echo ""
    echo -n "$node $ip reachable"
    # remove node from list
    nodelist="$((echo "$nodelist"; echo "$node") | sort | uniq -u)"
  else
    echo -n "."
  fi
  if [ $((secs--)) -eq 0 ]; then
    echo "Aborted, missing: $(echo "$nodelist" | paste -sd, -)"
    return 1;
  fi
done
echo ""
echo "Complete!"
}

wait_for_ssh() {
local secs=100
echo -n "Waiting ${secs} seconds for ssh to become reachable..."
local nodelist="$(for n in "${!NODES[@]}"; do echo $n; done)"
while test -n "$nodelist"; do
  node=$(echo "$nodelist" | shuf | head -n1)
  ip=$(node_ip $node)
  if nc -zv -w 1 $ip 22 > /dev/null 2>&1; then
    echo ""
    echo -n "$node $ip reachable"
    # remove node from list
    nodelist="$((echo "$nodelist"; echo "$node") | sort | uniq -u)"
  else
    # timeout has no effect since connection is rejected instantly
    # when network stack is up. maybe we can differentiate via return code?
    sleep 1
    echo -n "."
  fi
  if [ $((secs--)) -eq 0 ]; then
    echo "Aborted, missing: $(echo "$nodelist" | paste -sd, -)"
    return 1;
  fi
done
echo ""
echo "Complete!"
}

# use ssh-keyscan to add the ssh public key id. this is safe within the local computer.
# alternatively use virt-cat or qemu-guest-agent, https://chatgpt.com/c/68d8ecb3-2688-8333-ba5c-5f1765821da7
# or in .ssh/config do: Host 192.168.122.* UserKnownHostsFile=/dev/null
# for k0sctrl, you can also do env SSH_KNOWN_HOSTS=/dev/null
# https://github.com/k0sproject/k0sctl/issues/445#issuecomment-1378680320
add_ssh_key() {
local ip="$2"
local name="$1"
local known_hosts="$HOME/.ssh/known_hosts"
mkdir -p "$(dirname "$known_hosts")"
touch "$known_hosts"
ssh-keygen -R "$ip" -f "$known_hosts"
# default is 5 secs timeout
ssh-keyscan -T 15 -t ed25519 -H "$ip" >> "$known_hosts"
# echo add key for ${LAB_PREFIX}-${name}....
# add for the host if its existing
ssh-keyscan -T 15 -t ed25519 -H ${LAB_PREFIX}-${name} "$ip" >> "$known_hosts" || true
}

add_all_ssh_node_keys() {
echo "Adding ssh keys from nodes to ~/.ssh/known_hosts (via ssh-keyscan)"
#for ip in $(ips); do
#  add_ssh_key "$ip"
#done
for n in "${!NODES[@]}"; do
  read -r mem vcpus _ _ <<<"${NODES[$n]}"
  add_ssh_key $n $(node_ip $n)
done
}

# add the proxy ca to speed up downloads
add_proxy_ca_cert() {
test -f $PROXY_BUMP_CA_CRT || {
  echo "Skip installing interceptor cert..."
  return 0
}
local ip="$1"
scp "$PROXY_BUMP_CA_CRT" "$BASE_USER@$ip":ssl-bump-ca.crt
ssh "$BASE_USER@$1" sudo mv ssl-bump-ca.crt /usr/local/share/ca-certificates/
ssh "$BASE_USER@$1" sudo update-ca-certificates
}

add_all_proxy_ca_certs() {
if ! test -f "$PROXY_BUMP_CA_CRT"; then
  echo "No proxy bump ca cert at $PROXY_BUMP_CA_CRT, skipping..."
  return;
fi
echo "Add proxy ca certs"
for ip in $(ips); do
  add_proxy_ca_cert $ip
done
}

join_cmd() {
local seed
seed="$(seed_node)" || return 1
echo "Fetch kubeadm join command from $seed" >&2
ssh "$BASE_USER@$(node_ip "$seed")" 'sudo kubeadm token create --print-join-command'
}



join_workers() {
echo "Join worker nodes to the cluster"
local join
join="$(join_cmd)"
local workers=()
local n
for n in "${!NODES[@]}"; do
  if [ "$(node_role "$n")" = "wk" ]; then
    workers+=("$n")
  fi
done
if [ ${#workers[@]} -eq 0 ]; then
  echo "No worker nodes found"
  return 0
fi
local tmpdir script
tmpdir="$(mktemp -d /tmp/kube-join-workers.XXXXXX)"
script="$tmpdir/10-join-workers.sh"
cat > "$script" <<EOF
#!/usr/bin/env bash
set -euo pipefail
$join
EOF
chmod +x "$script"
local rc=0
if ! run_scripts_on_nodes "$tmpdir" "${workers[@]}"; then
  rc=$?
fi
rm -rf "$tmpdir"
return "$rc"
}

join_additional_cp_nodes() {
echo "Join additional control-plane nodes to the cluster"
local seed
seed="$(seed_node)" || return 1
local cert_key
cert_key="$(ssh "$BASE_USER@$(node_ip "$seed")" 'sudo kubeadm init phase upload-certs --upload-certs | tail -n1')"
local join
join="$(ssh "$BASE_USER@$(node_ip "$seed")" "sudo kubeadm token create --print-join-command --certificate-key $cert_key --control-plane")"
local n
local found=0
for n in "${!NODES[@]}"; do
  if [ "$(node_role "$n")" = "cp" ]; then
    found=1
    (
      echo "  -> $n"
      ssh "$BASE_USER@$(node_ip "$n")" 'sudo bash -s' <<<"$join"
    ) &
  fi
done
if [ $found -eq 0 ]; then
  echo "No additional control-plane nodes found"
  return 0
fi
wait
}

run_scripts_on_nodes() {
  local script_dir="$1"
  shift
  local nodes=("$@")
  local scripts=()
  local all_fifos=()
  local keepalive_fds=()
  local pids=()
  local mux_meta mux_pid
  local s n stream fifo key
  declare -A fifo_map=()
  # That’s to safely quote the value before embedding it into the remote ssh command string. printf -v ... "%q" turns the value into a shell-escaped form,
  # so if KUBE_VERSION is empty or contains odd characters, it won’t break the command or allow injection.

  local kube_version_q
  printf -v kube_version_q "%q" "${KUBE_VERSION:-}"

  if [ ! -d "$script_dir" ]; then
    echo "No $(basename "$script_dir") scripts found"
    return 0
  fi

  for s in "$script_dir"/*.sh; do
    scripts+=("$s")
  done

  if [ ${#scripts[@]} -eq 0 ]; then
    echo "No $(basename "$script_dir") scripts found"
    return 0
  fi

  if ! command -v python3 >/dev/null 2>&1; then
    echo "python3 is required for output mux in run_scripts_on_nodes" >&2
    return 1
  fi

  mux_meta="$(mktemp /tmp/kube-run-scripts-mux-meta.XXXXXX)"
  for n in "${nodes[@]}"; do
    for s in "${scripts[@]}"; do
      local script_name
      script_name="$(basename "$s")"
      for stream in OUT ERR INFO; do
        key="$n|$script_name|$stream"
        fifo="$(mktemp -u)"
        mkfifo "$fifo"
        fifo_map["$key"]="$fifo"
        all_fifos+=("$fifo")
        printf '%s\t%s\t%s\t%s\n' "$fifo" "$n" "$script_name" "$stream" >> "$mux_meta"
      done
    done
  done

  python3 -u - "$mux_meta" <<'PY' &
import datetime
import os
import selectors
import sys

meta_path = sys.argv[1]
entries = []
with open(meta_path, encoding="utf-8") as f:
    for raw in f:
        raw = raw.rstrip("\n")
        if not raw:
            continue
        fifo, host, script, stream = raw.split("\t")
        entries.append((fifo, host, script, stream))

sel = selectors.DefaultSelector()
buf = {}
meta = {}

for fifo, host, script, stream in entries:
    fd = os.open(fifo, os.O_RDONLY | os.O_NONBLOCK)
    sel.register(fd, selectors.EVENT_READ)
    buf[fd] = bytearray()
    meta[fd] = (host, script, stream)

def ts():
    return datetime.datetime.now(datetime.timezone.utc).astimezone().strftime("%Y-%m-%dT%H:%M:%S%z")

while meta:
    events = sel.select(timeout=1.0)
    if not events:
        continue
    for key, _ in events:
        fd = key.fd
        try:
            data = os.read(fd, 65536)
        except BlockingIOError:
            continue
        if data:
            b = buf[fd]
            b.extend(data)
            while True:
                nl = b.find(b"\n")
                if nl < 0:
                    break
                line = bytes(b[:nl])
                del b[: nl + 1]
                line = line.replace(b"\r", b"")
                host, script, stream = meta[fd]
                msg = line.decode("utf-8", "replace")
                sys.stdout.write(f"{ts()} {host} {script} {stream} {msg}\n")
                sys.stdout.flush()
        else:
            rem = bytes(buf[fd]).replace(b"\r", b"")
            if rem:
                host, script, stream = meta[fd]
                msg = rem.decode("utf-8", "replace")
                sys.stdout.write(f"{ts()} {host} {script} {stream} {msg}\n")
                sys.stdout.flush()
            sel.unregister(fd)
            os.close(fd)
            del buf[fd]
            del meta[fd]
PY
  mux_pid=$!

  for fifo in "${all_fifos[@]}"; do
    local fd
    exec {fd}> "$fifo"
    keepalive_fds+=("$fd")
  done

  for n in "${nodes[@]}"; do
    local ip
    ip="$(node_ip "$n")"
    (
      for s in "${scripts[@]}"; do
        local script_name
        local out_fifo err_fifo info_fifo start_ns end_ns elapsed_ns elapsed_tenths elapsed_s elapsed_d
        script_name="$(basename "$s")"
        key="$n|$script_name|OUT"
        out_fifo="${fifo_map[$key]}"
        key="$n|$script_name|ERR"
        err_fifo="${fifo_map[$key]}"
        key="$n|$script_name|INFO"
        info_fifo="${fifo_map[$key]}"
        printf 'START\n' > "$info_fifo"
        start_ns="$(date +%s%N)"
        ssh "$BASE_USER@$ip" "KUBE_VERSION=$kube_version_q tmp=\$(mktemp /tmp/kube-XXXXXX.sh); cat > \"\$tmp\"; sudo KUBE_VERSION=$kube_version_q bash \"\$tmp\"; rc=\$?; rm -f \"\$tmp\"; exit \$rc" < "$s" \
          1> "$out_fifo" \
          2> "$err_fifo"
        local rc=$?
        end_ns="$(date +%s%N)"
        elapsed_ns=$((end_ns - start_ns))
        elapsed_tenths=$(((elapsed_ns + 50000000) / 100000000))
        elapsed_s=$((elapsed_tenths / 10))
        elapsed_d=$((elapsed_tenths % 10))
        if [ $rc -ne 0 ]; then
          printf 'FAIL rc=%s\n' "$rc" > "$info_fifo"
          exit "$rc"
        fi
        printf 'DONE runtime=%s.%ss\n' "$elapsed_s" "$elapsed_d" > "$info_fifo"
      done
    ) &
    pids+=("$!")
  done
  local failed=0
  local pid
  for pid in "${pids[@]}"; do
    if ! wait "$pid"; then
      failed=1
    fi
  done

  local fd
  for fd in "${keepalive_fds[@]}"; do
    exec {fd}>&-
  done

  wait "$mux_pid"

  rm -f "$mux_meta"
  rm -f "${all_fifos[@]}"

  if [ $failed -ne 0 ]; then
    return 1
  fi
}

run_node_setup() {
  test -n "$NODE_SETUP" || return
  echo "Run $NODE_SETUP node setup scripts on all nodes"
  local nodes=()
  local n
  for n in "${!NODES[@]}"; do
    nodes+=("$n")
  done
  run_scripts_on_nodes "$BASE_DIR/node-setup/$NODE_SETUP/scripts.d" "${nodes[@]}"
}

run_seed_setup() {
  echo "Run $SEED_SETUP setup scripts on seed node"
  local seeds=()
  local n
  for n in "${!NODES[@]}"; do
    if [ "$(node_role "$n")" = "seed" ]; then
      seeds+=("$n")
    fi
  done
  if [ ${#seeds[@]} -ne 1 ]; then
    echo "Expected exactly one seed node, found ${#seeds[@]}" >&2
    return 1
  fi
  run_scripts_on_nodes "$BASE_DIR/seed-setup/$SEED_SETUP/scripts.d" "${seeds[0]}"
  # run_scripts_on_nodes "$CLUSTER_DIR/seed.d" "${seeds[0]}"
}

update_node() {
echo update node $1
(
ssh "$BASE_USER@$1" 'cat > update.sh' <<EOF
apt-get update
apt-get upgrade -y
apt-get install joe
EOF
ssh "$BASE_USER@$1" 'sudo bash update.sh'
) 2>&1 | awk "{print \"$1: \"\$0}"
}

purge_node() {
local n="$1"
local vm_name disk_name iso_name
vm_name="$(node_resource_name "$n")"
disk_name="$(node_disk_name "$n")"
iso_name="$(node_seed_iso_name "$n")"
virsh destroy "$vm_name" || true
virsh undefine "$vm_name" || true
virsh vol-delete --pool "$POOL" "$disk_name" || true
virsh vol-delete --pool "$POOL" "$iso_name" || true
}

purge_all_nodes() {
for n in "${!NODES[@]}"; do
  purge_node $n
done
}

fetch_kubeconfig() {
local seed ip out tmp cfg
seed="$(seed_node)" || {
return 1
}
ip="$(node_ip "$seed")"
out="$LAB_DIR/.kubeconfig"
tmp="$out.tmp.$$"
cfg=/etc/kubernetes/admin.conf
if ssh "$BASE_USER@$ip" "sudo test -f $cfg && sudo cat $cfg" > "$tmp"; then
  chmod 600 "$tmp"
  mv "$tmp" "$out"
  echo "Wrote kubeconfig to $out"
  echo "Use it with: KUBECONFIG=\"$out\" kubectl get nodes"
  echo "Or: export KUBECONFIG=\"$out\""
else
  rm -f "$tmp"
  echo "No kubeconfig at $cfg on $seed yet; skipping export."
  return 0
fi
}

up_nodes() {
summary
start_storage
start_network
create_base_volume
create_all_nodes
wait_for_ping
wait_for_ssh
add_all_ssh_node_keys
add_all_proxy_ca_certs
start_sync_daemons
run_node_setup
}

up_cluster() {
run_seed_setup
#join_additional_cp_nodes
join_workers
fetch_kubeconfig
}

has_cluster_node_roles() {
local n role
for n in "${!NODES[@]}"; do
  role="$(node_role "$n")"
  case "$role" in
    seed|cp|wk) return 0 ;;
  esac
done
return 1
}

up() {
up_nodes;
if has_cluster_node_roles; then
  up_cluster
else
  echo "No cluster node roles defined (seed/cp/wk); skipping cluster bootstrap."
fi
}

start() {
local vm_name
for n in "${!NODES[@]}"; do
  vm_name="$(node_resource_name "$n")"
  virsh start "$vm_name" || true
done
start_sync_daemons
}

stop() {
stop_sync_daemons
for n in "${!NODES[@]}"; do
  local vm_name
  vm_name="$(node_resource_name "$n")"
  virsh shutdown "$vm_name" >/dev/null 2>&1 || true
done
local deadline=$((SECONDS + 10))
local pending=()
local n
for n in "${!NODES[@]}"; do
  pending+=("$n")
done
while [ ${#pending[@]} -gt 0 ] && [ $SECONDS -lt $deadline ]; do
  local still=()
  for n in "${pending[@]}"; do
    local vm_name
    vm_name="$(node_resource_name "$n")"
    if virsh dominfo "$vm_name" >/dev/null 2>&1; then
      local state
      state="$(virsh domstate "$vm_name" 2>/dev/null || true)"
      if [[ "$state" != "shut off" && "$state" != "shutoff" ]]; then
        still+=("$n")
      fi
    fi
  done
  pending=("${still[@]}")
  [ ${#pending[@]} -gt 0 ] && sleep 1
done
for n in "${pending[@]}"; do
  local vm_name
  vm_name="$(node_resource_name "$n")"
  virsh destroy "$vm_name" || true
done
}

summary() {
for n in "${!NODES[@]}"; do
  read -r mem vcpus _ _ <<<"${NODES[$n]}"
  echo $n $(node_ip $n)
done
}

tt() {
local n="$1"
shift
ssh "$BASE_USER@$(node_ip $n)" "$@"
}

purge() {
stop_sync_daemons
purge_all_nodes
local net_name
net_name="$(network_resource_name)"
virsh net-destroy "$net_name" >/dev/null 2>&1 || true
virsh net-undefine "$net_name" >/dev/null 2>&1 || true
}

help() {
cat <<'EOF'
Usage: lab [--prefix name] <command> [args]

Options:
  --prefix name       Prefix host-side libvirt resources for this invocation
                      (same as LAB_PREFIX=name)

Lifecycle (most important):
  up                 Create/start nodes and run cluster bootstrap (if seed/cp/wk roles exist)
  start              Start all defined nodes
  stop               Stop sync daemons, then shut down all nodes
  purge              Destroy all nodes and remove the lab network

Cluster bootstrap:
  up_nodes           Infrastructure/node setup only
  up_cluster         Cluster bootstrap only (seed setup, worker joins, kubeconfig fetch)
  fetch_kubeconfig   Fetch kubeconfig into ./.kubeconfig
  run_seed_setup     Run seed setup scripts
  join_workers       Join worker nodes
  join_additional_cp_nodes
                     Join additional control-plane nodes

Sync:
  sync-list          Show active sync daemons
  sync-log [-f] [-n N]
                     Show sync logs; -f follow, -n number of lines

Status and access:
  summary            Show node names and IPs
  ips                Print all node IPs
  node_ip <node>     Print IP for one node
  tt <node> <cmd...> Run command on node over SSH

Infrastructure and utilities:
  check              Check required host dependencies and libvirt access
  start_storage      Ensure libvirt storage pool exists/started
  start_network      Ensure libvirt network exists/started
  create_base_volume Create base image volume
  purge_base_volume  Delete base image volume
  create_all_nodes   Create overlays/ISOs/VM definitions for all nodes
  wait_for_ping      Wait until all nodes answer ping
  wait_for_ssh       Wait until SSH is reachable on all nodes
  add_all_ssh_node_keys
                     Add node SSH host keys to known_hosts
  add_all_proxy_ca_certs
                     Install proxy CA cert on all nodes (if configured)
  run_node_setup     Run node setup scripts on all nodes
  run_seed_setup     Run seed setup scripts on seed cp node
  var <name>         Print a config variable value
  keyPath            Print SSH public key path
  help               Show this help

Config:
  LAB_PREFIX         Prefix libvirt domains, node volumes, seed ISOs, and network
                     names. Defaults to the normalized lab project directory name.
                     Node keys and cloud hostnames remain cp1/wk1/etc.
  NET_NAME           Libvirt network suffix. Defaults to lc.
  NET_PREFIX         Optional fixed IPv4 /24 prefix, for example 192.168.125.
                     If omitted, lab reuses an existing same-name libvirt
                     network or .network, otherwise allocates a free prefix.
  NET_PREFIX_POOL_BASE
  NET_PREFIX_POOL_START
  NET_PREFIX_POOL_END
                     Auto-allocation pool. Defaults to 192.168.120-199.
EOF
}

VALID_COMMANDS=(
  up
  start
  stop
  purge
  up_nodes
  up_cluster
  fetch_kubeconfig
  run_seed_setup
  join_workers
  join_additional_cp_nodes
  sync_list
  sync_log
  summary
  ips
  node_ip
  tt
  check
  start_storage
  start_network
  create_base_volume
  purge_base_volume
  create_all_nodes
  wait_for_ping
  wait_for_ssh
  add_all_ssh_node_keys
  add_all_proxy_ca_certs
  run_node_setup
  var
  keyPath
  help
)

is_valid_command() {
local needle="$1"
local c
for c in "${VALID_COMMANDS[@]}"; do
  if [ "$c" = "$needle" ]; then
    return 0
  fi
done
return 1
}

dispatch_command() {
while [ "$#" -gt 0 ]; do
  case "$1" in
    --prefix)
      if [ "$#" -lt 2 ]; then
        echo "Missing value for --prefix" >&2
        return 1
      fi
      LAB_PREFIX_OVERRIDE_SET=1
      LAB_PREFIX_OVERRIDE="$2"
      export LAB_PREFIX="$LAB_PREFIX_OVERRIDE"
      shift 2
      ;;
    --prefix=*)
      LAB_PREFIX_OVERRIDE_SET=1
      LAB_PREFIX_OVERRIDE="${1#*=}"
      export LAB_PREFIX="$LAB_PREFIX_OVERRIDE"
      shift
      ;;
    --)
      shift
      break
      ;;
    *)
      break
      ;;
  esac
done
local raw_cmd="${1:-}"
if [ -z "$raw_cmd" ]; then
  help
  return 0
fi
shift || true
local cmd="${raw_cmd//-/_}"
if ! is_valid_command "$cmd"; then
  echo "Unknown command: $raw_cmd" >&2
  echo
  help
  return 1
fi
if ! declare -F "$cmd" >/dev/null 2>&1; then
  echo "Command not implemented: $cmd" >&2
  return 1
fi
case "$cmd" in
  check) ;;
  *) read_config ;;
esac
"$cmd" "$@"
}

if ! is_sourced; then
  dispatch_command "$@"
fi
