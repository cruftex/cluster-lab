#!/usr/bin/env bash
set -euo pipefail

set -x

source_image="$1"
img="$2"
customizer="$3"

# the space for the additional packages may not be sufficient
# grow the partition
additional_g=10

cp -a "$source_image" "$img"
qemu-img resize "$img" +${additional_g}G
chown $SUDO_USER:$SUDO_USER "$img"

modprobe nbd

dev=""
for d in /sys/class/block/nbd[0-9]; do
  [ -e "$d" ] || continue
  cand=$(basename "$d")
  if [ ! -e "$d/pid" ]; then
    dev="$cand"
    break
  fi
done

if [ -z "$dev" ]; then
  echo "No free /dev/nbdN device found" >&2
  exit 1
fi

wait_for_partition() {
  for i in {1..50}; do
    lsblk -n "$1" | grep -q part && return 0
    sleep 0.1
  done
  echo "Timed out waiting for partition device $part" >&2
  return 1
}

mnt=$(mktemp -d)

cleanup() {
  df -h $mnt
  (
    cd $mnt
    # this is dangerous, do it better in chroot!
    rm -f customizer.sh
    rm -f etc/resolv.conf
    if test -d etc; then
      ln -s ../run/systemd/resolve/stub-resolv.conf etc/resolv.conf
    fi
  )
  umount $mnt/dev $mnt/proc $mnt/sys 2>/dev/null || true
  umount $mnt 2>/dev/null || true
  qemu-nbd --disconnect /dev/$dev || true
  rm -rf $mnt
}

trap cleanup EXIT

qemu-nbd --connect=/dev/$dev "$img"
growpart /dev/$dev 1

# make sure devices for partions are available
partprobe /dev/$dev
udevadm settle || true
part=/dev/${dev}p1
wait_for_partition "$part"

e2fsck -f "$part"
resize2fs "$part"

mkdir -p "$mnt"

mount "$part" "$mnt"
mount --bind /dev $mnt/dev
mount --bind /proc $mnt/proc
mount --bind /sys $mnt/sys

df -h $mnt

cp -a $customizer $mnt/customizer.sh
(
  cd $mnt
  rm -f etc/resolv.conf
  echo "nameserver 1.1.1.1" > etc/resolv.conf
)

chroot $mnt bash /customizer.sh

exit 0;

# some old stuff, experimented with virt-customize
# does not work well, always missing the network

proxy_url="${1:-http://localhost:3128/}"

# Inside libguestfs networking, host localhost is reachable as 10.0.2.2.
guest_proxy_url="${proxy_url/localhost/10.0.2.2}"


# Force libguestfs working dirs to writable locations.
cache_dir=/tmp/libguestfs-cache
tmp_dir=/tmp/libguestfs-tmp
runtime_dir=/tmp/libguestfs-runtime
resolv_conf=/tmp/libguestfs-resolv.conf
mkdir -p "$cache_dir" "$tmp_dir" "$runtime_dir"

# Build a resolver file usable from inside the libguestfs appliance.
{
  awk '/^nameserver / {print "nameserver " $2}' /run/systemd/resolve/resolv.conf
  echo "nameserver 1.1.1.1"
  echo "nameserver 8.8.8.8"
} > "$resolv_conf"

export LIBGUESTFS_RESOLV_CONF="$resolv_conf"
export LIBGUESTFS_CACHEDIR="$cache_dir"
export TMPDIR="$tmp_dir"
export XDG_RUNTIME_DIR="$runtime_dir"
export LIBGUESTFS_SOCKDIR="$runtime_dir"
export LIBGUESTFS_DEBUG=1
export LIBGUESTFS_TRACE=1

virt-customize -a "$custom" \
#    --run-command "printf 'Acquire::http::Proxy \"%s\";\nAcquire::https::Proxy \"%s\";\n' '$guest_proxy_url' '$guest_proxy_url' > /etc/apt/apt.conf.d/90proxy" \
    --run-command "printf 'nameserver 1.1.1.1\nnameserver 8.8.8.8\n' > /etc/resolv.conf" \
    --run-command "apt-get -o Acquire::Retries=3 update" \
    --run-command "DEBIAN_FRONTEND=noninteractive apt-get -y install joe curl ca-certificates gnupg apt-transport-https" \
    --run-command "mkdir -p /etc/apt/keyrings" \
    --run-command "curl -x '$guest_proxy_url' -fsSL https://pkgs.k8s.io/core:/stable:/v1.29/deb/Release.key -o /tmp/k8s.key" \
    --run-command "gpg --dearmor /tmp/k8s.key > /etc/apt/keyrings/kubernetes-apt-keyring.gpg" \
    --run-command "echo 'deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v1.29/deb/ /' > /etc/apt/sources.list.d/kubernetes.list" \
    --run-command "apt-get -o Acquire::Retries=3 update" \
    --run-command "DEBIAN_FRONTEND=noninteractive apt-get -y install kubelet kubeadm kubectl"
